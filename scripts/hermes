#!/data/data/com.termux/files/usr/bin/bash
#
# Hermes Agent launcher — transparently enters Ubuntu + activates venv
# Installed by nous_agent.sh to $PREFIX/bin/hermes
# Usage: hermes [args...]
#
exec proot-distro login ubuntu -- bash -c '
cd "$HOME/hermes-agent" && source venv/bin/activate && exec hermes "$@"
' -- "$@"
